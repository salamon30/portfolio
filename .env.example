# Copy to .env.local and fill in your values.
# .env.local is git-ignored and never committed.

# ─── Public: site URL used for SEO, sitemap, OG tags ───
# In production set this to your real domain.
NEXT_PUBLIC_SITE_URL="https://recepulasuzun.com"

# ─── Contact form: Resend (https://resend.com) ───
# Without RESEND_API_KEY the form silently falls back to mailto links.
# 1. Create a free account at resend.com
# 2. Create an API key → paste it below
# 3. Verify a sending domain (or keep the default "onboarding@resend.dev"
#    which works for testing)
RESEND_API_KEY=""

# Where incoming portfolio messages are delivered. Defaults to your hotmail.
CONTACT_TO_EMAIL="ulasch_uzun@hotmail.com"

# Who the email appears to be from. Must be on a verified Resend domain.
# For quick testing you can leave this as the default sandbox sender.
CONTACT_FROM_EMAIL="Portfolio <onboarding@resend.dev>"
